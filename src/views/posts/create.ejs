<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            background: radial-gradient(circle at top, #0f172a, #020617);
        }
    </style>
</head>

<body class="text-gray-200 font-sans">

<div class="max-w-5xl mx-auto py-12 px-6">

    <!-- Top Bar -->
    <div class="flex justify-between items-center mb-10">
        <h1 class="text-4xl font-semibold tracking-tight text-white">
            Create Post
        </h1>
        <a href="/" class="text-sm text-gray-400 hover:text-white transition">
            ← Back to Home
        </a>
    </div>

    <!-- Card -->
    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 shadow-xl">

        <!-- Flash -->
        <% if (success) { %>
            <div class="mb-6 p-4 rounded-lg bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                <%= success %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="mb-6 p-4 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20">
                <%= error %>
            </div>
        <% } %>

        <form action="/posts/new/create" method="POST" class="space-y-8">

            <!-- Title -->
            <div>
                <input 
                    type="text" 
                    name="title" 
                    placeholder="Post title..."
                    required
                    class="w-full text-3xl font-semibold bg-transparent border-b border-white/10 focus:border-blue-500 outline-none py-2 placeholder-gray-500"
                >
            </div>

            <!-- Content -->
            <div>
                <textarea 
                    name="content" 
                    rows="10" 
                    placeholder="Start writing your story..."
                    required
                    class="w-full bg-transparent border border-white/10 rounded-xl p-4 focus:border-blue-500 outline-none resize-none placeholder-gray-500"
                ></textarea>
            </div>

            <!-- Grid Section -->
            <div class="grid md:grid-cols-2 gap-6">

                <!-- Excerpt -->
                <div>
                    <label class="text-sm text-gray-400">Excerpt</label>
                    <textarea 
                        name="excerpt" 
                        rows="3"
                        class="w-full mt-2 bg-transparent border border-white/10 rounded-lg p-3 focus:border-blue-500 outline-none"
                    ></textarea>
                </div>

                <!-- Tags -->
                <div>
                    <label class="text-sm text-gray-400">Tags</label>
                    <input 
                        type="text" 
                        name="tags" 
                        placeholder="tech, javascript, backend"
                        class="w-full mt-2 bg-transparent border border-white/10 rounded-lg p-3 focus:border-blue-500 outline-none"
                    >
                </div>

            </div>

            <!-- SEO Toggle -->
            <div>
                <button type="button" onclick="toggleSEO()" 
                    class="text-sm text-blue-400 hover:text-blue-300 transition">
                    Advanced SEO Options ↓
                </button>

                <div id="seoSection" class="hidden mt-4 space-y-4">
                    <input type="text" name="meta_title" placeholder="Meta title"
                        class="w-full bg-transparent border border-white/10 rounded-lg p-3">

                    <textarea name="meta_description" rows="2" placeholder="Meta description"
                        class="w-full bg-transparent border border-white/10 rounded-lg p-3"></textarea>

                    <input type="text" name="meta_keywords" placeholder="Meta keywords"
                        class="w-full bg-transparent border border-white/10 rounded-lg p-3">
                </div>
            </div>

            <!-- Footer -->
            <div class="flex justify-between items-center pt-6 border-t border-white/10">

                <!-- Publish -->
                <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
                    <input type="checkbox" name="is_published" value="true" class="accent-blue-500">
                    Publish now
                </label>

                <!-- Button -->
                <button 
                    type="submit"
                    class="bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded-lg font-medium transition shadow-lg shadow-blue-500/20"
                >
                    Publish →
                </button>

            </div>

        </form>
    </div>
</div>

<script>
    function toggleSEO() {
        const el = document.getElementById("seoSection");
        el.classList.toggle("hidden");
    }
</script>

</body>
</html>