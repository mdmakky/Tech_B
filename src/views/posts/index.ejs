<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %>
    </title>
    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: radial-gradient(circle at top, #0f172a, #020617);
        }

        .post-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>

<body class="text-gray-200 font-sans">

    <!-- Navbar -->
    <%- include('../partials/navbar') %>

        <!-- Hero Section -->
        <section class="text-center py-20">
            <h1 class="text-5xl font-bold text-white mb-4">Welcome to TechNest Blog</h1>
            <p class="text-gray-400 max-w-2xl mx-auto">
                Stay updated with the latest tech trends, tutorials, and insights from our experts.
            </p>
        </section>

        <!-- Main Content -->
        <main class="max-w-7xl mx-auto px-6 py-12">
            <% if (posts && posts.length> 0) { %>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% posts.forEach(post=> { %>
                        <div
                            class="post-card bg-gradient-to-tr from-gray-900/40 to-gray-800/40 backdrop-blur-xl border border-white/10 rounded-3xl p-6 transition-transform duration-300">
                            <h2 class="text-2xl font-bold text-white mb-2 hover:text-blue-400 transition">
                                <a href="/posts/<%= post.slug %>">
                                    <%= post.title %>
                                </a>
                            </h2>
                            <p class="text-gray-400 mb-4 line-clamp-3">
                                <%= post.excerpt %>
                            </p>
                            <div class="flex justify-between items-center text-sm text-gray-400 mb-3">
                                <span>By <span class="font-medium">
                                        <%= post.author_name %>
                                    </span></span>
                                <span>
                                    <%= new Date(post.created_at).toLocaleDateString() %>
                                </span>
                            </div>
                            <div class="flex gap-4 text-gray-400 text-sm mb-3">
                                <span>💬 <%= post.comment_count %></span>
                                <span>👍 <%= post.upvotes %></span>
                                <span>👎 <%= post.downvotes %></span>
                            </div>
                            <div class="text-xs text-gray-500">
                                Tags: <%= post.tags || 'none' %>
                            </div>
                            <div class="mt-4">
                                <a href="/posts/<%= post.slug %>"
                                    class="inline-block text-blue-400 hover:text-white font-medium">
                                    Read More →
                                </a>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <p class="text-gray-400 text-center mt-10 text-lg">No posts yet. Stay tuned!</p>
                    <% } %>
        </main>

        <!-- Footer -->
    <%- include('../partials/footer') %>

</body>

</html>