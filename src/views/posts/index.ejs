<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= metaDescription || 'TechNest — Deep dives into programming, AI, system design, and the tech stories that matter.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <!-- Ambient background effects -->
  <div class="home-bg" aria-hidden="true"></div>
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <div class="page-wrap">
    <%- include('../partials/navbar') %>

    <!-- =============================================
         HERO SECTION
         ============================================= -->
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-glow"></div>
        
        <div class="hero-content">
          <div class="hero-label">
            <span class="icon-dot">●</span>
            Fast. Simple. Powerful.
          </div>

          <h1 class="hero-title">
            Your Platform for<br/>
            <span class="gradient-text">Technical Excellence</span>
          </h1>

          <p class="hero-subtitle">
            Share deep technical insights, learn from expert developers, and grow your skills in a distraction-free environment.
          </p>

          <div class="hero-buttons">
            <% if (currentUser) { %>
              <a href="/posts/new/create" class="btn btn-primary btn-lg">
                <span class="btn-icon">✏️</span> Write an Article
              </a>
              <a href="/posts" class="btn btn-outline btn-lg">
                <span class="btn-icon">📖</span> Explore Articles
              </a>
            <% } else { %>
              <a href="/auth/register" class="btn btn-primary btn-lg">
                <span class="btn-icon">🚀</span> Get Started Free
              </a>
              <a href="/posts" class="btn btn-outline btn-lg">
                <span class="btn-icon">📖</span> Browse Articles
              </a>
            <% } %>
          </div>

          <div class="hero-scroll">
            <span>Discover great reads</span>
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </div>
        </div>
<!-- 
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-number"><%= posts ? posts.length : 0 %></div>
            <div class="stat-label">Articles</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-number">100%</div>
            <div class="stat-label">Free</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-number">0</div>
            <div class="stat-label">Ads</div>
          </div>
        </div> -->
      </div>
    </section>

    <!-- =============================================
         FEATURED SECTION
         ============================================= -->
    <% if (posts && posts.length > 0) { %>
      <% const featured = posts[0]; %>
      <section class="featured-section">
        <div class="section-label">⭐ Featured This Week</div>
        
        <a href="/posts/<%= featured.slug %>" class="featured-card-large">
          <div class="featured-card-badge">
            <% const emojis = ['💡','🔧','🚀','⚙️','🧠','💻','🔥','🌐','📊','🛠️']; %>
            <%= emojis[Math.abs(featured.title.charCodeAt(0)) % emojis.length] %>
          </div>
          
          <div class="featured-card-content">
            <div class="featured-card-meta">
              <% if (featured.tags) { %>
                <% featured.tags.split(',').slice(0, 2).forEach(tag => { %>
                  <span class="tag-mini">#<%= tag.trim() %></span>
                <% }) %>
              <% } %>
              <span class="featured-dot">•</span>
              <span class="featured-date"><%= new Date(featured.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </div>
            
            <h2 class="featured-card-title"><%= featured.title %></h2>
            <p class="featured-card-desc"><%= featured.excerpt || featured.content.substring(0, 150) %></p>
            
            <div class="featured-card-author">
              <div class="author-avatar">
                <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= featured.author_name %>" alt="">
              </div>
              <div class="author-info">
                <div class="author-name"><%= featured.author_name %></div>
                <div class="author-read">5 min read</div>
              </div>
              <div class="read-arrow">→</div>
            </div>
          </div>
        </a>
      </section>

      <!-- =============================================
           LATEST ARTICLES
           ============================================= -->
      <section class="articles-section">
        <div class="section-header">
          <h2 class="section-title">Latest Articles</h2>
          <a href="/posts" class="view-all">View All →</a>
        </div>

        <div class="articles-grid-home">
          <% posts.slice(1, 4).forEach(post => { %>
            <article class="card">
              <div class="card-header">
                <% if (post.tags) { %>
                  <span class="tag-mini">#<%= post.tags.split(',')[0].trim() %></span>
                <% } %>
              </div>
              
              <h3 class="card-title">
                <a href="/posts/<%= post.slug %>"><%= post.title %></a>
              </h3>
              
              <p class="card-excerpt"><%= post.excerpt || post.content.substring(0, 100) %>...</p>
              
              <div class="card-footer">
                <div class="card-author">
                  <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= post.author_name %>" alt="" class="card-avatar">
                  <span><%= post.author_name %></span>
                </div>
                <span class="card-date"><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
              </div>
            </article>
          <% }) %>
        </div>

        <% if (posts.length > 3) { %>
          <div class="cta-section">
            <p>Interested in more? We have <%= posts.length %> articles in total.</p>
            <a href="/posts" class="btn btn-primary">Explore All</a>
          </div>
        <% } %>
      </section>

    <% } else { %>
      <!-- Empty state -->
      <section class="empty-section">
        <div class="empty-icon">📭</div>
        <h2 class="empty-title">No Articles Yet</h2>
        <p class="empty-desc">Be the first to share your knowledge with our community.</p>
        <% if (currentUser) { %>
          <a href="/posts/new/create" class="btn btn-primary">Write the First Article</a>
        <% } else { %>
          <a href="/auth/register" class="btn btn-primary">Join & Start Writing</a>
        <% } %>
      </section>
    <% } %>

    <%- include('../partials/footer') %>
  </div><!-- .page-wrap -->

</body>
</html>