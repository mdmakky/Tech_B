<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Post | TechNest</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <%- include('../partials/navbar') %>

  <div class="editor-page">

    <div class="editor-topbar">
      <h1 class="editor-title">✏️ Edit Post</h1>
      <a href="/posts/<%= post.slug %>" class="btn btn-secondary btn-sm">← Back to Post</a>
    </div>

    <div class="editor-card">

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">✅ <%= success %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">❌ <%= error %></div>
      <% } %>

      <form action="/posts/<%= post.slug %>/edit" method="POST" class="editor-form">

        <!-- Title -->
        <div class="form-group">
          <input type="text" name="title" value="<%= post.title %>"
                 required class="form-input form-input-xl"
                 autocomplete="off">
        </div>

        <!-- Content -->
        <div class="form-group">
          <label class="form-label">Content <small style="color:var(--text-muted);font-style:italic;text-transform:none">(Markdown supported)</small></label>
          <textarea name="content" rows="12" required
                    class="form-input form-textarea" style="resize:vertical"><%= post.content %></textarea>
        </div>

        <!-- Excerpt + Tags -->
        <div class="editor-grid">
          <div class="form-group">
            <label class="form-label">Excerpt</label>
            <textarea name="excerpt" rows="3"
                      class="form-input form-textarea" style="resize:none"><%= post.excerpt || '' %></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Tags</label>
            <input type="text" name="tags" value="<%= post.tags || '' %>"
                   placeholder="tech, javascript, node" class="form-input">
            <small style="font-size:0.75rem;color:var(--text-muted)">Comma separated</small>
          </div>
        </div>

        <!-- SEO -->
        <div>
          <button type="button" class="seo-toggle-btn" onclick="toggleSEO()">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            SEO Options
          </button>
          <div id="seoSection" class="seo-section">
            <div class="form-group">
              <label class="form-label">Meta Title</label>
              <input type="text" name="meta_title" value="<%= post.meta_title || '' %>"
                     class="form-input">
            </div>
            <div class="form-group">
              <label class="form-label">Meta Description</label>
              <textarea name="meta_description" rows="2"
                        class="form-input form-textarea" style="resize:none"><%= post.meta_description || '' %></textarea>
            </div>
            <div class="form-group">
              <label class="form-label">Meta Keywords</label>
              <input type="text" name="meta_keywords" value="<%= post.meta_keywords || '' %>"
                     class="form-input">
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="editor-footer">
          <label class="checkbox-row">
            <input type="checkbox" name="is_published" value="true"
                   <%= post.is_published ? 'checked' : '' %>>
            <span style="font-size:0.9rem;color:var(--text-secondary)">Published</span>
          </label>
          <button type="submit" class="btn btn-primary">💾 Update Post</button>
        </div>

      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function toggleSEO() {
      document.getElementById('seoSection').classList.toggle('open');
    }
  </script>

</body>
</html>