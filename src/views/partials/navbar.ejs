<nav class="bg-gray-900 text-gray-100 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">

      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-indigo-400 hover:text-indigo-300">
          TechBlog
        </a>
      </div>

      <!-- Menu -->
      <div class="hidden md:flex space-x-6 items-center">
        <a href="/" class="hover:text-indigo-400 transition-colors">Home</a>
        <a href="/about" class="hover:text-indigo-400 transition-colors">About</a>
        <a href="/blog" class="hover:text-indigo-400 transition-colors">Blog</a>
        <a href="/contact" class="hover:text-indigo-400 transition-colors">Contact</a>
      </div>

      <!-- Auth Buttons -->
      <div class="flex items-center space-x-4">
        <% if (currentUser) { %>

          <span class="text-gray-300 hidden sm:inline">
            Hello, <%= currentUser.username %>
          </span>

          <form action="/auth/logout" method="POST">
            <button
              class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded transition-colors text-white font-semibold">
              Logout
            </button>
          </form>

        <% } else { %>

          <a href="/auth/login"
            class="bg-indigo-500 hover:bg-indigo-600 px-4 py-2 rounded transition-colors text-white font-semibold">
            Login
          </a>

          <a href="/auth/register"
            class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded transition-colors text-white font-semibold">
            Register
          </a>

        <% } %>

      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="focus:outline-none">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden px-4 pb-4">
    <a href="/" class="block py-2 hover:text-indigo-400">Home</a>
    <a href="/about" class="block py-2 hover:text-indigo-400">About</a>
    <a href="/blog" class="block py-2 hover:text-indigo-400">Blog</a>
    <a href="/contact" class="block py-2 hover:text-indigo-400">Contact</a>

    <% if (currentUser) { %>

      <div class="text-gray-300 py-2">
        Hello, <%= currentUser.username %>
      </div>

      <form action="/auth/logout" method="POST">
        <button
          class="w-full py-2 bg-red-500 hover:bg-red-600 text-white rounded mt-2">
          Logout
        </button>
      </form>

    <% } else { %>

      <a href="/auth/login"
        class="block py-2 bg-indigo-500 text-white rounded mt-2 text-center">
        Login
      </a>

      <a href="/auth/register"
        class="block py-2 bg-gray-700 text-white rounded mt-2 text-center">
        Register
      </a>

    <% } %>

  </div>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  </script>
</nav>