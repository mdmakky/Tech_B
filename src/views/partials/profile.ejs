<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | TechNest</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <%- include('../partials/navbar') %>

  <div class="profile-page">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">❌ <%= error %></div>
    <% } %>

    <!-- Profile Header -->
    <div class="profile-header">
      <div class="profile-avatar-ring">
        <img src="<%= user.avatar || `https://api.dicebear.com/7.x/initials/svg?seed=${user.username}` %>"
             alt="<%= user.username %>" loading="lazy">
      </div>

      <div class="profile-info">
        <h1 class="profile-username"><%= user.username %></h1>
        <p class="profile-bio"><%= user.bio || 'No bio yet. Tell us about yourself!' %></p>

        <div class="profile-stats">
          <span class="profile-stat profile-stat-blue">
            📝 <%= user.postsCount %> Posts
          </span>
          <span class="profile-stat" style="background:rgba(99,102,241,0.1);color:var(--accent-light);border:1px solid rgba(99,102,241,0.2)">
            🎖️ <%= user.role === 'admin' ? 'Admin' : 'Member' %>
          </span>
        </div>

        <div style="margin-top:18px;display:flex;gap:10px;flex-wrap:wrap">
          <a href="/posts/new/create" class="btn btn-primary btn-sm">
            ✏️ Write New Post
          </a>
        </div>
      </div>
    </div>

    <!-- Posts -->
    <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-primary);letter-spacing:-0.02em;margin-bottom:20px">
      Your Posts
    </h2>

    <% if (user.posts && user.posts.length > 0) { %>
      <div class="profile-posts-grid">
        <% user.posts.forEach(post => { %>
          <div class="profile-post-card">
            <div>
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                <% if (post.is_published) { %>
                  <span class="badge badge-green">● Published</span>
                <% } else { %>
                  <span class="badge badge-amber">○ Draft</span>
                <% } %>
              </div>
              <a href="/posts/<%= post.slug %>" class="profile-post-title">
                <%= post.title %>
              </a>
              <p style="font-size:0.85rem;color:var(--text-muted);margin-top:8px;line-height:1.55">
                <%= post.excerpt ? post.excerpt.substring(0, 120) + '...' : (post.content ? post.content.substring(0, 120) + '...' : '') %>
              </p>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;font-size:0.8rem;color:var(--text-muted)">
              <span><%= new Date(post.created_at).toLocaleDateString() %></span>
              <span>👁 <%= post.view_count || 0 %></span>
            </div>
            <div style="display:flex;gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)">
              <a href="/posts/<%= post.slug %>/edit" class="btn btn-warning btn-sm">Edit</a>
              <form action="/posts/<%= post.slug %>/delete" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete this post permanently?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="text-align:center;padding:60px;color:var(--text-muted)">
        <p style="font-size:2.5rem;margin-bottom:12px">✍️</p>
        <p style="font-size:1rem;margin-bottom:20px">You haven't written anything yet.</p>
        <a href="/posts/new/create" class="btn btn-primary">Write Your First Post</a>
      </div>
    <% } %>

  </div>

  <%- include('../partials/footer') %>

</body>
</html>