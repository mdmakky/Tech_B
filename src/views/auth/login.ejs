<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 min-h-screen flex items-center justify-center font-sans">

    <div class="bg-gray-900 text-gray-100 p-10 rounded-3xl shadow-2xl max-w-md w-full border border-gray-700">
        <h1 class="text-3xl font-bold mb-6 text-center text-indigo-400">Login to Your Account</h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-600 text-white p-3 rounded mb-4 text-center">
                <%= error %>
            </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-600 text-white p-3 rounded mb-4 text-center">
                <%= success %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-4">
            <div>
                <label for="email" class="block mb-1 font-semibold">Email</label>
                <input type="email" name="email" id="email" placeholder="Enter your email"
                    class="w-full p-3 rounded bg-gray-800 text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-400">
            </div>

            <div>
                <label for="password" class="block mb-1 font-semibold">Password</label>
                <input type="password" name="password" id="password" placeholder="Enter your password"
                    class="w-full p-3 rounded bg-gray-800 text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-400">
            </div>

            <button type="submit" 
                class="w-full bg-indigo-500 hover:bg-indigo-600 transition-colors py-3 rounded font-bold text-white">
                Login
            </button>
        </form>

        <p class="text-center text-gray-400 mt-4">
            Don't have an account? <a href="/auth/register" class="text-indigo-400 hover:underline">Register</a>
        </p>
    </div>

</body>
</html>