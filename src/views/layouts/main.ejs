<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TechBlog</title>

<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-gray-100 min-h-screen flex flex-col">

<!-- Navbar -->
<%- include('../partials/navbar') %>


<!-- Hero Section -->
<section class="flex-grow flex items-center justify-center text-center px-6 py-20">
    <div class="max-w-3xl">
        <h1 class="text-5xl font-bold mb-6 leading-tight">
            Share Your <span class="text-indigo-400">Ideas</span> With The World
        </h1>

        <p class="text-gray-400 text-lg mb-8">
            A modern tech blog platform where developers share knowledge,
            ideas, and experiences about programming, AI, and technology.
        </p>

        <div class="flex justify-center gap-4">
            <a href="/blog" class="bg-indigo-500 hover:bg-indigo-600 px-6 py-3 rounded-lg font-semibold transition">
                Explore Blogs
            </a>

            <% if(!currentUser){ %>
            <a href="/auth/register" class="bg-gray-700 hover:bg-gray-600 px-6 py-3 rounded-lg font-semibold transition">
                Get Started
            </a>
            <% } %>
        </div>
    </div>
</section>


<!-- Featured Posts -->
<section class="max-w-7xl mx-auto px-6 pb-16">
    <h2 class="text-3xl font-bold mb-10 text-center text-indigo-400">
        Featured Articles
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

        <!-- Post Card -->
        <div class="bg-gray-900 rounded-xl shadow-lg p-6 hover:shadow-indigo-500/20 transition">
            <h3 class="text-xl font-semibold mb-3">
                Understanding JavaScript Closures
            </h3>

            <p class="text-gray-400 mb-4">
                Learn how closures work in JavaScript and why they are important for advanced programming patterns.
            </p>

            <a href="#" class="text-indigo-400 hover:underline">
                Read More →
            </a>
        </div>

        <!-- Post Card -->
        <div class="bg-gray-900 rounded-xl shadow-lg p-6 hover:shadow-indigo-500/20 transition">
            <h3 class="text-xl font-semibold mb-3">
                Node.js Backend Architecture
            </h3>

            <p class="text-gray-400 mb-4">
                Explore how to structure scalable Node.js applications with controllers, models, and services.
            </p>

            <a href="#" class="text-indigo-400 hover:underline">
                Read More →
            </a>
        </div>

        <!-- Post Card -->
        <div class="bg-gray-900 rounded-xl shadow-lg p-6 hover:shadow-indigo-500/20 transition">
            <h3 class="text-xl font-semibold mb-3">
                Introduction to Machine Learning
            </h3>

            <p class="text-gray-400 mb-4">
                A beginner-friendly guide to machine learning concepts and how to start building ML models.
            </p>

            <a href="#" class="text-indigo-400 hover:underline">
                Read More →
            </a>
        </div>

    </div>
</section>


<!-- CTA Section -->
<section class="bg-gray-900 py-16 text-center border-t border-gray-800">
    <h2 class="text-3xl font-bold mb-4">
        Want to Share Your Knowledge?
    </h2>

    <p class="text-gray-400 mb-6">
        Join our community and start publishing your tech articles today.
    </p>

    <% if(!currentUser){ %>
    <a href="/auth/register" class="bg-indigo-500 hover:bg-indigo-600 px-8 py-3 rounded-lg font-semibold transition">
        Create Account
    </a>
    <% } %>
</section>


<!-- Footer -->
<%- include('../partials/footer') %>

</body>
</html>